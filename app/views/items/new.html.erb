<h1>New Item</h1>

<%= form_with(model: @item, local: true) do |f| %>
  <p>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </p>

  <p>
    <%= f.label :description %><br>
    <%= f.text_area :description %>
  </p>

  <p>
    <%= f.label :price %><br>
    <%= f.number_field :price %>
  </p>

  <p>
    <%= f.label :stock %><br>
    <%= f.number_field :stock %>
  </p>

  <p>
    <%= f.submit "Create Item" %>
  </p>
<% end %>

<%= link_to 'Back to List', items_path %>